# ZenControl OAuth 2.0 credentials
# Obtain these from ZenControl support: https://support.zencontrol.com/hc/en-us/requests/new
ZENCONTROL_CLIENT_ID=your_client_id_here
ZENCONTROL_CLIENT_SECRET=your_client_secret_here

# Optional: Override the default redirect URI (default: http://localhost:9000/callback)
# ZENCONTROL_REDIRECT_URI=http://localhost:9000/callback

# Optional: Override the server port for HTTP mode (default: 9000)
# ZENCONTROL_PORT=9000
